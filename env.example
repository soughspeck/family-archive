# Server
PORT=3000

# Database
DB_PATH=./family-archive.db

# Media storage
# In dev: local uploads folder
# In prod: swap MEDIA_BASE_URL to your R2 public URL
MEDIA_BASE_URL=http://localhost:3000/uploads
UPLOADS_DIR=./uploads

# R2 (leave empty in dev, fill in when moving to VPS)
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# App
APP_NAME=Family Archive
