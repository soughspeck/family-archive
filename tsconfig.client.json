    "moduleResolution": "node",
    "outDir": "./client/js",
    "rootDir": "./client/ts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["client/ts/**/*"]
}
