{
  "name": "family-archive",
  "version": "0.1.0",
  "description": "Personal family archive — photos, videos, audio, documents",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:client": "tsc --watch --project tsconfig.client.json",
    "build": "tsc && tsc --project tsconfig.client.json",
    "build:client": "tsc --project tsconfig.client.json",
    "start": "node dist/server/index.js",
    "db:migrate": "tsx server/db/migrate.ts"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
